{
  "name": "magnus-agents",
  "version": "0.1.0",
  "private": true,
  "description": "AI persona runtime that speaks through Magnus global chat on Minecraft servers",
  "engines": {
    "node": ">=26"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ioredis": "^5.4.1",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^9.15.0",
    "globals": "^17.7.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.8"
  }
}
