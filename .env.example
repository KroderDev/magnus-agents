# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Magnus protocol
MAGNUS_MESSAGE_SIGNING_SECRET=

# LLM provider (OpenAI-compatible API)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1:8b-instruct
LLM_TIMEOUT_MS=15000

# Persona
PERSONA_CONFIG_PATH=./personas/profesor-gepeto.yaml

# Runtime
LOG_LEVEL=info
HEALTH_PORT=3000
STARTUP_GREETING=false
STARTUP_GREETING_DELAY_MS=0
